# Copy to .env and fill in values for local dev. For Fly.io, set with `fly secrets set ...`.

# === xAI ===
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_REALTIME_URL=wss://api.x.ai/v1/realtime
XAI_MODEL=grok-voice-think-fast-1.0
XAI_VOICE=ara

# === Twilio ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15155551234
TWILIO_VALIDATE_SIGNATURE=true

# === OpenPhone ===
OPENPHONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENPHONE_DEFAULT_FROM=+15155551234

# === HubSpot booking ===
# Existing Make.com webhook — DO NOT change (shared infrastructure)
HUBSPOT_MAKE_WEBHOOK=https://hook.<region>.make.com/<your-booking-webhook>
# Optional: direct HubSpot for availability via Private App
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_AVAILABILITY_USER_ID=

# === Transfer destinations ===
ATTORNEY_TRANSFER_NUMBER=+15555550100
VOICEMAIL_NUMBER=+15555550101

# === Supabase Postgres (call logging) ===
# Use the transaction pooler URL (port 6543), not the direct connection (5432).
# Find it in Supabase Studio → Project Settings → Database → Connection pooling.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_POOL_MIN=2
SUPABASE_DB_POOL_MAX=10

# === Supabase Storage (call recordings) ===
# Both required to upload + serve call recordings. Bucket "call-recordings"
# must exist (private). Service-role key from Project Settings → API.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...long-jwt-from-project-settings...

# === Cost rates (USD; placeholders, refine from xAI docs / Twilio billing) ===
XAI_COST_INPUT_AUDIO_PER_1K=0.030
XAI_COST_OUTPUT_AUDIO_PER_1K=0.060
XAI_COST_INPUT_TEXT_PER_1K=0.0025
XAI_COST_OUTPUT_TEXT_PER_1K=0.010
TWILIO_INBOUND_COST_PER_MIN=0.0085
TWILIO_OUTBOUND_COST_PER_MIN=0.013

# === Admin dashboard (Phase 2) ===
# Generate the bcrypt hash with:
#   .venv/Scripts/python.exe -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# === Public hostname ===
# Local dev: paste your ngrok URL (https://abc123.ngrok-free.app)
# Production: https://acme-voice-agent.fly.dev
HOSTNAME=https://acme-voice-agent.fly.dev

# === Server ===
PORT=8000
LOG_LEVEL=INFO
ENV=dev
